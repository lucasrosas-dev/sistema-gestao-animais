# Uso local: deixe DATABASE_URL vazio para usar data/sistema_animais.db.
APP_ENV=development
SECRET_KEY=desenvolvimento-local-troque-esta-chave-antes-de-publicar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
SESSION_MAX_AGE=28800
COOKIE_SECURE=false
RESET_ADMIN_PASSWORD=false

